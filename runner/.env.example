# GitHub repo info
GITHUB_OWNER=menglingjie
GITHUB_REPO=aetftrace

# Runner token (get from Settings -> Actions -> Runners -> New self-hosted runner)
# Token expires after 1 hour, but once the runner registers it stays active
RUNNER_TOKEN=AXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Runner name (optional)
RUNNER_NAME=domestic-runner

# App env vars (passed through to the workflow)
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
